---
const services = [
  {
    num: '01',
    title: 'AI Agents',
    blurb: 'Autonomous task-runners — support triage, sales ops, back-office busywork, research.',
  },
  {
    num: '02',
    title: 'RAG Systems',
    blurb: 'Your internal knowledge, queryable — docs, tickets, code, customer calls.',
  },
  {
    num: '03',
    title: 'Workflow Automation',
    blurb: 'The unsexy pipes: webhooks, queues, retries, guardrails — the stuff that keeps agents honest.',
  },
  {
    num: '04',
    title: 'Integrations',
    blurb: 'HubSpot, Slack, Stripe, your weird internal API — we wire it all in.',
  },
  {
    num: '05',
    title: 'AI Consulting',
    blurb: 'Not sure where to start? A short engagement to map the highest-leverage opportunities.',
  },
];
---

<section class="services" id="services">
  <div class="wrap">
    <div class="section-head reveal-up">
      <div>
        <div class="eyebrow">What we build</div>
        <h2 style="margin-top:18px;">
          Five services, <span class="serif" style="font-style:italic; color:var(--amber-dark);">one team</span>, zero fluff.
        </h2>
      </div>
      <p class="aside">
        Pragmatic agent systems shipped by operators who've done this before. Pick one workflow, or let's map the whole thing.
      </p>
    </div>

    <div class="service-list">
      {services.map((s) => (
        <a class="service-row reveal-up" href="#contact">
          <span class="num">{s.num}</span>
          <h3>{s.title}</h3>
          <p>{s.blurb}</p>
          <span class="go">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M1 13L13 1M13 1H3M13 1V11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .services { background: var(--paper); }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
    margin-bottom: 70px;
    flex-wrap: wrap;
  }
  .section-head h2 { max-width: 780px; }
  .section-head .aside {
    color: var(--muted);
    font-size: 15px;
    max-width: 320px;
  }

  .service-row {
    display: grid;
    grid-template-columns: 60px 1.2fr 1.8fr auto;
    gap: 32px;
    align-items: center;
    padding: 34px 8px;
    border-top: 1px solid var(--line);
    position: relative;
    cursor: pointer;
    transition: padding .4s cubic-bezier(.2, .7, .2, 1);
    text-decoration: none;
  }
  .service-row:last-child { border-bottom: 1px solid var(--line); }
  .service-row .num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.05em;
  }
  .service-row h3 {
    font-size: clamp(28px, 3.4vw, 44px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1;
    transition: color .3s, transform .4s cubic-bezier(.2, .7, .2, 1);
  }
  .service-row p {
    font-size: 15px;
    color: var(--muted);
    transition: color .3s;
  }
  .service-row .go {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid var(--line-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    transition: all .3s ease;
  }
  .service-row .go svg { transition: transform .3s; }
  .service-row::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--amber);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform .4s cubic-bezier(.2, .7, .2, 1);
    z-index: -1;
  }
  .service-row:hover::before { transform: scaleY(1); transform-origin: top; }
  .service-row:hover { padding-left: 24px; padding-right: 24px; }
  .service-row:hover h3 { color: var(--ink); }
  .service-row:hover .num,
  .service-row:hover p { color: var(--ink); }
  .service-row:hover .go {
    background: var(--ink);
    color: var(--amber);
    border-color: var(--ink);
  }
  .service-row:hover .go svg { transform: translateX(3px) translateY(-3px); }

  @media (max-width: 960px) {
    .service-row {
      grid-template-columns: 40px 1fr auto;
      gap: 16px;
    }
    .service-row p { display: none; }
  }
</style>
