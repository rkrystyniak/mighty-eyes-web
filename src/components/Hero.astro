---
import Terminal from './Terminal.astro';
---

<section class="hero" id="top">
  <div class="wrap hero-grid">
    <div>
      <div class="eyebrow hero-eyebrow">Agentic workflows for startups &amp; SMBs</div>
      <h1 class="hero-headline" style="margin-top:20px;">
        <span class="reveal"><span>Use AI to</span></span><br />
        <span class="reveal">
          <span class="accent cycler" aria-live="polite">
            <span class="cycler-word is-active">add value</span>
            <span class="cycler-word">save time</span>
            <span class="cycler-word">cut costs</span>
          </span>
        </span>
      </h1>
      <p class="hero-sub">
          We design, build, and operate AI agents that do the work — so you can cut costs, save time, and focus on growing your business.
      </p>
      <div class="hero-ctas">
        <a href="#contact" class="btn btn-primary">
          Let's Talk About Your Project <span class="arrow">→</span>
        </a>
        <a href="#services" class="btn btn-ghost">What we build</a>
      </div>
    </div>

    <Terminal />
  </div>
</section>

<style>
  .hero {
    padding-top: 160px;
    padding-bottom: 100px;
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 80% 60% at 80% 30%, rgba(245, 159, 10, 0.08), transparent 60%),
      radial-gradient(ellipse 60% 50% at 10% 80%, rgba(22, 31, 54, 0.06), transparent 60%);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 70px;
    align-items: center;
    position: relative;
  }

  .hero-headline {
    font-size: clamp(56px, 8vw, 104px);
    font-weight: 800;
    line-height: 0.98;
    letter-spacing: -0.035em;
  }
  .hero-headline .reveal {
    display: inline-block;
    overflow: hidden;
    vertical-align: top;
  }
  .hero-headline .reveal > span {
    display: inline-block;
    transform: translateY(110%);
    animation: rise 1s cubic-bezier(.2, .7, .2, 1) forwards;
  }
  .hero-headline .reveal:nth-child(1) > span { animation-delay: .10s; }
  .hero-headline .reveal:nth-child(2) > span { animation-delay: .20s; }
  .hero-headline .reveal:nth-child(3) > span { animation-delay: .30s; }
  .hero-headline .reveal:nth-child(4) > span { animation-delay: .40s; }
  .hero-headline .reveal:nth-child(5) > span { animation-delay: .50s; }
  .hero-headline .reveal:nth-child(6) > span { animation-delay: .60s; }

  .hero-headline .accent {
    position: relative;
    white-space: nowrap;
    color: var(--ink);
  }
  .hero-headline .accent::after {
    content: "";
    position: absolute;
    left: -4px;
    right: -4px;
    bottom: 6%;
    height: 38%;
    background: var(--amber);
    z-index: -1;
    transform: scaleX(0);
    transform-origin: left;
    animation: wipe 0.9s cubic-bezier(.7, .1, .3, 1) 1.1s forwards;
  }

  .hero-headline .reveal > span.cycler {
    display: inline-grid;
    grid-template-columns: max-content;
    grid-auto-rows: max-content;
    vertical-align: top;
    padding: 0 0.08em;
  }
  .hero-headline .cycler > .cycler-word {
    grid-area: 1 / 1;
    justify-self: start;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(40%);
    transition:
      opacity .45s cubic-bezier(.2, .7, .2, 1),
      transform .45s cubic-bezier(.2, .7, .2, 1);
    will-change: opacity, transform;
  }
  .hero-headline .cycler > .cycler-word.is-active {
    opacity: 1;
    transform: translateY(0);
  }
  .hero-headline .cycler > .cycler-word.is-leaving {
    opacity: 0;
    transform: translateY(-40%);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-headline .cycler > .cycler-word,
    .hero-headline .cycler > .cycler-word.is-active,
    .hero-headline .cycler > .cycler-word.is-leaving {
      transform: none;
      transition: opacity .3s ease;
    }
  }

  .hero-eyebrow { opacity: 0; animation: fade-up .7s ease-out .05s forwards; }
  .hero-sub {
    font-size: 19px;
    line-height: 1.55;
    max-width: 440px;
    margin-top: 28px;
    color: var(--muted);
    opacity: 0;
    animation: fade-up .8s ease-out .8s forwards;
  }
  .hero-ctas {
    display: flex;
    gap: 14px;
    margin-top: 36px;
    flex-wrap: wrap;
    opacity: 0;
    animation: fade-up .8s ease-out 1.0s forwards;
  }

  @media (max-width: 960px) {
    .hero { padding-top: 120px; }
    .hero-grid { grid-template-columns: 1fr; gap: 48px; }
  }
</style>

<script>
  const hero = document.querySelector<HTMLElement>('.hero');
  if (hero) {
    window.addEventListener(
      'scroll',
      () => {
        const y = Math.min(window.scrollY, 600);
        hero.style.setProperty('--py', y + 'px');
      },
      { passive: true }
    );
  }

  const words = document.querySelectorAll<HTMLElement>('.cycler-word');
  if (words.length > 1) {
    let i = 0;
    const INTERVAL = 2400;
    const START_DELAY = 1600;
    setTimeout(() => {
      setInterval(() => {
        const current = words[i];
        i = (i + 1) % words.length;
        const next = words[i];
        current.classList.remove('is-active');
        current.classList.add('is-leaving');
        next.classList.add('is-active');
        setTimeout(() => current.classList.remove('is-leaving'), 500);
      }, INTERVAL);
    }, START_DELAY);
  }
</script>
