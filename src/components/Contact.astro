---
---

<section class="contact" id="contact">
  <div class="wrap contact-grid">
    <div class="reveal-up">
      <div class="eyebrow-light">Let's talk</div>
      <h2 style="margin-top:18px;">
        Tell us about<br />your <span class="serif" style="font-style:italic; color:var(--amber);">project</span>.
      </h2>
      <p class="lead">
        Grab a 30-minute slot that works for you and we'll dig into the workflow you're trying to automate. Not sure what you want to automate?
          No problem. We'll work together to uncover the opportunities with the greatest ROI.
      </p>
    </div>

    <div class="form reveal-up d1">
      <!-- Google Calendar Appointment Scheduling begin -->
      <iframe
        src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ1Scmvaf4NOcOSaJvgu44diICMR9FXpCsHKApz_BS8-svgb5huOen8cRmqlTdF_TXmP3sSJVDX3?gv=true"
        style="border: 0"
        width="100%"
        height="600"
        title="Schedule a meeting with Mighty Eyes"
      ></iframe>
      <!-- end Google Calendar Appointment Scheduling -->
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--ink);
    color: var(--paper);
    padding: 120px 40px 100px;
    position: relative;
    overflow: hidden;
  }
  .contact::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 40% 50% at 90% 20%, rgba(245, 159, 10, 0.18), transparent 60%),
      radial-gradient(ellipse 50% 40% at 10% 90%, rgba(245, 159, 10, 0.08), transparent 60%);
    pointer-events: none;
  }
  .contact :global(h2),
  .contact :global(.serif) { color: var(--paper); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 80px;
    align-items: start;
    position: relative;
    z-index: 1;
  }
  .contact :global(h2) {
    font-size: clamp(42px, 5vw, 68px);
    font-weight: 700;
    letter-spacing: -0.025em;
  }
  .lead {
    color: var(--muted-2);
    font-size: 17px;
    max-width: 400px;
    margin-top: 22px;
  }

  .promise {
    margin-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .promise-item {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--muted-2);
    font-size: 14px;
  }
  .promise-item .check {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(245, 159, 10, 0.15);
    color: var(--amber);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .form {
    background: #fff;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 20px;
    padding: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
  }
  .form iframe {
    display: block;
    width: 100%;
    border-radius: 12px;
    background: #fff;
    color-scheme: light;
  }

  @media (max-width: 960px) {
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    .form { padding: 8px; }
  }
</style>
